#!/usr/bin/env bash

# GitHub Identity Manager
# Manages multiple SSH keys for github.com

CONFIG_DIR="$HOME/.config/gh-id"
IDENTITIES_FILE="$CONFIG_DIR/identities.conf"
SSH_GITHUB_CONF="$HOME/.ssh/github_identity"
SSH_CONFIG="$HOME/.ssh/config"

# Create config directory if it doesn't exist
mkdir -p "$CONFIG_DIR"
mkdir -p "$HOME/.ssh"

# Ensure ~/.ssh/config includes the github_identity file
if [[ ! -f "$SSH_CONFIG" ]]; then
    echo "Include github_identity" > "$SSH_CONFIG"
    chmod 600 "$SSH_CONFIG"
elif ! grep -q "Include github_identity" "$SSH_CONFIG"; then
    # Add Include at the top
    sed -i '1iInclude github_identity' "$SSH_CONFIG"
fi

function usage() {
    echo "GitHub Identity Manager"
    echo "Usage: gh-id [command]"
    echo ""
    echo "Commands:"
    echo "  add <name> <path> [user.name] [user.email]  Add a new identity"
    echo "  remove <name>                               Remove an identity"
    echo "  list                                        List all saved identities"
    echo "  switch <name>                               Switch the active GitHub identity"
    echo "  status                                      Show the current active identity"
}

function add_identity() {
    local name=$1
    local path=$2
    local git_name=$3
    local git_email=$4

    if [[ -z "$name" || -z "$path" ]]; then
        echo "Error: Name and path required"
        echo "Usage: gh-id add <name> <path> [user.name] [user.email]"
        return 1
    fi
    
    # Resolve path to absolute if it exists
    if [[ -f "$path" ]]; then
        path=$(realpath "$path")
    else
        echo "Error: SSH key file not found at $path"
        return 1
    fi

    # Check if name already exists
    if grep -q "^$name:" "$IDENTITIES_FILE" 2>/dev/null; then
        echo "Error: Identity '$name' already exists. Remove it first if you want to update it."
        return 1
    fi

    echo "$name:$path:$git_name:$git_email" >> "$IDENTITIES_FILE"
    echo "Added identity '$name' -> $path"
    if [[ -n "$git_name" ]]; then
        echo "  Git Name:  $git_name"
    fi
    if [[ -n "$git_email" ]]; then
        echo "  Git Email: $git_email"
    fi
}

function remove_identity() {
    local name=$1
    if [[ -z "$name" ]]; then
        echo "Error: Name required"
        echo "Usage: gh-id remove <name>"
        return 1
    fi
    
    if ! grep -q "^$name:" "$IDENTITIES_FILE" 2>/dev/null; then
        echo "Error: Identity '$name' not found."
        return 1
    fi

    # Check if we are removing the active one
    local current_path=$(grep "IdentityFile" "$SSH_GITHUB_CONF" 2>/dev/null | awk '{print $2}')
    local entry=$(grep "^$name:" "$IDENTITIES_FILE" 2>/dev/null)
    local path=${entry#*:}

    if [[ "$path" == "$current_path" ]]; then
        echo "Warning: Removing the active identity. You should switch to another one."
    fi

    sed -i "/^$name:/d" "$IDENTITIES_FILE"
    echo "Removed identity '$name'"
}

function list_identities() {
    if [[ ! -f "$IDENTITIES_FILE" ]] || [[ ! -s "$IDENTITIES_FILE" ]]; then
        echo "No identities saved yet."
        return
    fi
    
    local current_path=$(grep "IdentityFile" "$SSH_GITHUB_CONF" 2>/dev/null | awk '{print $2}')
    
    printf "%-3s %-15s %-25s %-20s %s\n" "" "NAME" "GIT NAME" "GIT EMAIL" "PATH"
    printf "%-3s %-15s %-25s %-20s %s\n" "" "----" "--------" "---------" "----"
    
    while IFS=: read -r name path git_name git_email; do
        local marker="  "
        if [[ "$path" == "$current_path" ]]; then
            marker="* "
        fi
        printf "%-3s %-15s %-25s %-20s %s\n" "$marker" "$name" "${git_name:-N/A}" "${git_email:-N/A}" "$path"
    done < "$IDENTITIES_FILE"
    
    echo ""
    echo "(*) indicates active identity"
}

function switch_identity() {
    local name=$1
    if [[ -z "$name" ]]; then
        echo "Error: Name required"
        echo "Usage: gh-id switch <name>"
        return 1
    fi
    
    local entry=$(grep "^$name:" "$IDENTITIES_FILE" 2>/dev/null)
    if [[ -z "$entry" ]]; then
        echo "Error: Identity '$name' not found. Use 'gh-id list' to see available ones."
        return 1
    fi
    
    IFS=: read -r id_name id_path id_git_name id_git_email <<< "$entry"
    
    # Update SSH config
    cat > "$SSH_GITHUB_CONF" <<EOF
# Generated by gh-id. Do not edit manually.
Host github.com
  HostName github.com
  User git
  IdentityFile $id_path
  IdentitiesOnly yes
EOF
    chmod 600 "$SSH_GITHUB_CONF"

    # Update Git config locally if in a git repo
    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        if [[ -n "$id_git_name" ]]; then
            git config --local user.name "$id_git_name"
            echo "Set local git user.name to: $id_git_name"
        fi
        if [[ -n "$id_git_email" ]]; then
            git config --local user.email "$id_git_email"
            echo "Set local git user.email to: $id_git_email"
        fi
    else
        echo "Note: Not inside a Git repository. Local git config not updated."
        if [[ -n "$id_git_name" || -n "$id_git_email" ]]; then
            echo "Identity includes Git details: ${id_git_name:-N/A} <${id_git_email:-N/A}>"
            echo "Run 'gh-id switch $name' again when inside a Git repository to apply these."
        fi
    fi

    echo "Successfully switched to identity '$name'"
}

function show_status() {
    if [[ ! -f "$SSH_GITHUB_CONF" ]]; then
        echo "No GitHub identity is currently managed by gh-id (using system defaults)."
        return
    fi
    
    local current_path=$(grep "IdentityFile" "$SSH_GITHUB_CONF" | awk '{print $2}')
    local entry=$(grep ":$current_path\(:\|$\)" "$IDENTITIES_FILE" 2>/dev/null)
    IFS=: read -r name path git_name git_email <<< "$entry"
    
    if [[ -n "$name" ]]; then
        echo "Current identity: $name"
        echo "Key path:         $current_path"
        echo "Configured Git:   ${git_name:-N/A} <${git_email:-N/A}>"
    else
        echo "Current identity: Unknown (path: $current_path)"
    fi

    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "--- Current Repository Config ---"
        echo "Local user.name:  $(git config --local user.name || echo '(not set)')"
        echo "Local user.email: $(git config --local user.email || echo '(not set)')"
    fi
}

case $1 in
    add)
        add_identity "$2" "$3" "$4" "$5"
        ;;
    remove)
        remove_identity "$2"
        ;;
    list)
        list_identities
        ;;
    switch)
        switch_identity "$2"
        ;;
    status)
        show_status
        ;;
    *)
        usage
        ;;
esac
