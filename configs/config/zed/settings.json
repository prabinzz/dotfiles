// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // --- UI & Appearance ---
  "ui_font_family": "JetBrainsMono Nerd Font",
  "ui_font_size": 18.0,
  "ui_font_weight": 600.0,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 18.0,
  "buffer_font_weight": 600,
  "buffer_line_height": { "custom": 1.5 },
  "buffer_font_features": { "calt": false },
  "agent_ui_font_size": 16,
  "agent_buffer_font_size": 16,
  "icon_theme": "Warm Charmed Icons",

  // --- Theme ---
  "theme": {
    "mode": "dark",
    "light": "VSCode Light+",
    "dark": "Aura Dark"
  },
  "theme_overrides": {
    "Aura Dark": {
      "border.variant": "#15141c",
      "border": "#222222",
      "title_bar.background": "#15141c",
      "panel.background": "#15141c",
      "panel.focused_border": "#4e4665e",
      "players": [
        {
          "cursor": "#bd9dff"
        }
      ],
      "syntax": {
        "comment": {
          "font_style": "italic"
        },
        "comment.doc": {
          "font_style": "italic"
        }
      }
    }
  },

  // --- Editor Behavior ---
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "multi_cursor_modifier":"cmd_or_ctrl",
  "cursor_blink": false,
  "drag_and_drop_selection":{
    "enabled": false,
  },
  "seed_search_query_from_cursor":"never",
  "current_line_highlight": "none",
  "tab_size": 2,
  "auto_indent": "syntax_aware",
  "auto_indent_on_paste": false,
  "inline_code_actions": false,
  "format_on_save": "off",
  "which_key": {
    "enabled": true
  },
  "extend_comment_on_newline": false,
  "vertical_scroll_margin": 10,
  "horizontal_scroll_margin": 5,

  // --- UI Cleanup & Panels ---
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left",
    "default_width": 500,
    "auto_fold_dirs": false,
  },
  "gutter":{
    "min_line_number_digits": 0,
    "folds": false,
  },
  "file_finder":{
    "modal_max_width": "medium"
  },
  "outline_panel": {
    "dock": "right",
    "default_width": 300
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left",
    "tree_view": false
  },
  "title_bar": {
    "show_project_items": false,
    "show_user_menu": false,
    "show_sign_in": false
  },
  "tab_bar": {
    "show": false
  },
  "toolbar": {
    "quick_actions": false
  },
  "status_bar": {
    "experimental.show": false
  },

  // --- AI / Assistant ---
  "agent_servers": {
    "gemini": {
      "type": "registry"
    }
  },
  "agent": {
    "sidebar_side": "right",
    "flexible": false,
    "dock": "right",
    "inline_assistant_model": {
      "provider": "google",
      "model": "gemini-2.5-flash"
    },
    "default_model": {
      "provider": "google",
      "model": "gemini-3-flash-preview"
    },
    "commit_message_model": {
      "provider": "google",
      "model": "gemini-2.5-flash"
    },
    "model_parameters": []
  },
  // --- LSP ---
  "lsp": {
    "gopls": {
      "initialization_options": {
        "usePlaceholders": false,
        "completeFunctionCalls": true
      }
    },
    "clangd": {
      "binary": {
        "arguments": ["--function-arg-placeholders=0"]
      }
    }
  },

  // --- Miscellaneous ---
  "tasks": {
    "enabled": true
  }
}
