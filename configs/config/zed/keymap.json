// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": "file_finder::Toggle",
      "ctrl \\": "project_panel::CollapseAllEntries",
      "ctrl-shift-r": "pane::RevealInProjectPanel",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-e": "project_panel::ToggleFocus",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space f": "editor::Format",
      "space i": "editor::OrganizeImports",
      "space e": "project_panel::ToggleFocus",
      "space e e": "workspace::ToggleLeftDock",
      "ctrl-j": "editor::DuplicateLineDown",
      "ctrl-[": "editor::Fold",
      "ctrl-]": "editor::UnfoldLines",
      "space w": "pane::CloseActiveItem",
      "space w w": "pane::CloseOtherItems",
      "space b": "tab_switcher::Toggle",
      "space b d": "pane::CloseActiveItem",
      "ctrl-a": "editor::SelectAll",
    },
  },
]
